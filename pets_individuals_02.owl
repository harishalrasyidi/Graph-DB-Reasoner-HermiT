@prefix : <http://example.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.org/> .

<http://example.org/> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://example.org/hasPet
:hasPet rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :owns ;
        rdfs:domain :PetOwner ;
        rdfs:range :PetAnimal .


###  http://example.org/owns
:owns rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf owl:topObjectProperty .


#################################################################
#    Classes
#################################################################

###  http://example.org/Animal
:Animal rdf:type owl:Class .


###  http://example.org/Anjing
:Anjing rdf:type owl:Class ;
        rdfs:subClassOf :PetAnimal .


###  http://example.org/Kucing
:Kucing rdf:type owl:Class ;
        rdfs:subClassOf :PetAnimal .


###  http://example.org/OwnsPetAnimal
:OwnsPetAnimal rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Restriction ;
                                     owl:onProperty :owns ;
                                     owl:someValuesFrom :PetAnimal
                                   ] ;
               rdfs:subClassOf :PetOwner .


###  http://example.org/PetAnimal
:PetAnimal rdf:type owl:Class ;
           rdfs:subClassOf :Animal ;
           owl:disjointWith :WildAnimal .


###  http://example.org/PetOwner
:PetOwner rdf:type owl:Class .


###  http://example.org/WildAnimal
:WildAnimal rdf:type owl:Class ;
            rdfs:subClassOf :Animal .


#################################################################
#    Individuals
#################################################################

###  http://example.org/Budi
:Budi rdf:type owl:NamedIndividual ;
      :hasPet :Tweety .


###  http://example.org/Dani
:Dani rdf:type owl:NamedIndividual ;
      :owns :Tom .


###  http://example.org/Endang
:Endang rdf:type owl:NamedIndividual ;
        :hasPet :Simba .


###  http://example.org/Simba
:Simba rdf:type owl:NamedIndividual ,
                :WildAnimal .


###  http://example.org/Tom
:Tom rdf:type owl:NamedIndividual ,
              :Kucing .


###  http://example.org/Tweety
:Tweety rdf:type owl:NamedIndividual .


